{
  "name": "@openflip/flipper-rpc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run proto:gen && tsc",
    "dev": "tsc --watch",
    "proto:gen": "node scripts/generate-proto.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@openflip/shared": "*",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
